# LiteLLM / kurum ici LLM
LITELLM_URL=https://litellm.fibabanka.local/v1/chat/completions
LITELLM_API_KEY=
LLM_MODEL=openai/gpt-oss-120b

# Internal sertifika icin varsayilan false tutuldu.
# Gerekirse true yapabilirsiniz.
LITELLM_VERIFY_SSL=false
LITELLM_TIMEOUT=60
LLM_CONTEXT_WINDOW=131072

# Oracle DB baglantisi (USE_DB=true icin opsiyonel)
USE_DB=false
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_NPS_TABLE=
