# ── Groq (ücretsiz, önerilen) ─────────────────────────────────────────────────
# console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_...

# Model seçenekleri (128k context):
#   llama-3.1-8b-instant   → hızlı, ücretsiz
#   llama-3.3-70b-versatile → daha güçlü, ücretsiz (rate limit daha düşük)
LLM_MODEL=llama-3.1-8b-instant

# ── On-prem / kurum içi (opsiyonel) ───────────────────────────────────────────
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=http://your-onprem-host:port/v1
# LLM_MODEL=gpt-oss120b
